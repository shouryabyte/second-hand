# Backend environment variables (example)
# Copy to `backend/.env` for local dev.
# For Vercel: set these in Project Settings Ã¢â€ â€™ Environment Variables.

PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/sh_marketplace

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# CORS (comma-separated allowed origins)
# Example: https://your-frontend.vercel.app,https://your-frontend-git-main.vercel.app
CORS_ORIGIN=http://localhost:3000

# Rate limits
RATE_LIMIT_PER_15M=600
AUTH_RATE_LIMIT_PER_10M=60

# Make specified emails admin (comma-separated)
ADMIN_EMAILS=admin@example.com

# OTP
# In production you should send OTP via SMS/Email; for demos you can echo OTP in the response.
OTP_HASH_SECRET=change_me_in_production
OTP_ECHO_TO_RESPONSE=true

# Upload provider: cloudinary | local
# NOTE: Local uploads are not supported on Vercel; use Cloudinary.
UPLOAD_PROVIDER=cloudinary

# Cloudinary (required when UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=sh-marketplace

# Groq (AI helpers)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
# Razorpay
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret